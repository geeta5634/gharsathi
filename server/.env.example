# ─── Server ──────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Database ────────────────────────────────────────
# Path to SQLite database file (relative to server/)
DB_PATH=data/gharsathi.db

# ─── JWT ─────────────────────────────────────────────
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────
# Comma-separated list of allowed origins (use * for all)
CORS_ORIGINS=*

# ─── Rate Limiting ───────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── SMS (pick one provider) ──────────────────────────
# Options: console, twilio, fast2sms, rapidapi
# console = OTP printed in logs / shown on screen
SMS_PROVIDER=console

# Fast2SMS
# FAST2SMS_API_KEY=your_api_key
# FAST2SMS_SENDER_ID=TXTIND

# RapidAPI
# RAPID_API_KEY=your_key
# RAPID_API_HOST=your_host
# RAPID_API_URL=your_url

# ─── OAuth (Google) ──────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add http://localhost:3001/api/auth/google/callback as authorized redirect URI
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── OAuth (Facebook) ────────────────────────────────
# Create app at https://developers.facebook.com
# Add http://localhost:3001/api/auth/facebook/callback as valid OAuth redirect URI
# FACEBOOK_APP_ID=your-facebook-app-id
# FACEBOOK_APP_SECRET=your-facebook-app-secret

# ─── Base URL (used for OAuth callback construction) ─
BASE_URL=http://localhost:3001

# ─── Seed Data (change on production) ────────────────
SEED_PASSWORD=password123
