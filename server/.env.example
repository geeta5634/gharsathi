# ─── Server ──────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Database (Turso) ────────────────────────────────
# Get a free database at https://turso.tech
# Install CLI: npm install -g @turso/cli
# Create DB:   turso db create gharsathi
# Get URL:     turso db show gharsathi --url
# Get Token:   turso db tokens create gharsathi
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# ─── JWT ─────────────────────────────────────────────
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────
# Comma-separated list of allowed origins (use * for all)
CORS_ORIGINS=*

# ─── Rate Limiting ───────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── SMS / OTP ────────────────────────────────────────
# Options: console (unlimited free dev mode), startmessaging, fast2sms, rapidapi
#
# console   = OTP shown on screen + printed in logs (unlimited, free, no API key needed)
#             Best for testing / development. 9999 OTPs per minute per phone.
#
# startmessaging = ₹0.25/OTP, no DLT registration needed, free test credits on signup
#             Get API key: https://startmessaging.com (5 minute setup)
#
# fast2sms  = Requires FAST2SMS_API_KEY. Free credits on signup. DLT registered needed.
#
# rapidapi  = Requires RAPID_API_KEY + RAPID_API_HOST + RAPID_API_URL. Pay per OTP.
SMS_PROVIDER=console

# StartMessaging (recommended for India – no DLT requirement)
# Sign up at https://startmessaging.com, get free test credits instantly
# STARTMESSAGING_API_KEY=your_api_key_here
# STARTMESSAGING_BASE_URL=https://api.startmessaging.com

# Fast2SMS (legacy)
# FAST2SMS_API_KEY=your_api_key
# FAST2SMS_SENDER_ID=TXTIND

# RapidAPI
# RAPID_API_KEY=your_key
# RAPID_API_HOST=your_host
# RAPID_API_URL=your_url

# ─── OAuth (Google) ──────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add http://localhost:3001/api/auth/google/callback as authorized redirect URI
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── OAuth (Facebook) ────────────────────────────────
# Create app at https://developers.facebook.com
# Add http://localhost:3001/api/auth/facebook/callback as valid OAuth redirect URI
# FACEBOOK_APP_ID=your-facebook-app-id
# FACEBOOK_APP_SECRET=your-facebook-app-secret

# ─── Base URL (used for OAuth callback construction) ─
BASE_URL=http://localhost:3001

# ─── Seed Data (change on production) ────────────────
SEED_PASSWORD=password123
