{
  "name": "gharsathi-backend",
  "version": "1.0.0",
  "description": "GharSathi booking backend with Razorpay integration",
  "main": "src/index.js",
  "scripts": {
    "dev": "node src/index.js",
    "start": "node src/index.js",
    "build": "npx prisma generate",
    "postinstall": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:generate": "npx prisma generate",
    "db:seed": "node prisma/seed.js",
    "db:reset": "npx prisma db push --force-reset && node prisma/seed.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "razorpay": "^2.9.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "prisma": "^5.10.0"
  }
}
